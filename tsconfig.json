{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/client",
    "src/shared",
    "src/engine",
    "src/importers",
    "src/interview",
    "tests",
    "vite.config.ts"
  ]
}
